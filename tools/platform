#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

########################################
# CONFIG
########################################

TAG_KEY="Role"
TAG_VALUE="ops"
REGION="us-east-1"
REGISTRY="046685909731.dkr.ecr.us-east-1.amazonaws.com"

COMMAND="${1:-}"
SERVICE="${2:-}"

########################################
# HELP
########################################

usage() {
  cat <<EOF
Usage:
  platform up
  platform down
  platform state
  platform state-pull
  platform list
  platform describe <service>
  platform rehydrate
  platform deploy <service>
  platform restart <service>
  platform logs <service>
  platform status <service>
  platform register <service> <port> <domain>
  platform deregister <service>
  platform shell
EOF
  exit 1
}

########################################
# GET INSTANCE ID
########################################

get_instance_id() {
  aws ec2 describe-instances \
    --region "$REGION" \
    --filters "Name=tag:${TAG_KEY},Values=${TAG_VALUE}" \
    --query "Reservations[*].Instances[*].InstanceId" \
    --output text | awk '{print $1}'
}

INSTANCE_ID=$(get_instance_id)

if [ -z "$INSTANCE_ID" ]; then
  echo "❌ No instance found with tag ${TAG_KEY}=${TAG_VALUE}"
  exit 1
fi

########################################
# WAIT FOR INSTANCE
########################################

wait_for_running() {
  echo "Waiting for instance..."

  for i in {1..30}; do
    STATE=$(aws ec2 describe-instances \
      --region "$REGION" \
      --instance-ids "$INSTANCE_ID" \
      --query "Reservations[].Instances[].State.Name" \
      --output text)

    if [[ "$STATE" == "running" ]]; then
      echo "Instance is running"
      return
    fi

    sleep 5
  done

  echo "❌ Instance not ready"
  exit 1
}

########################################
# SSM EXEC (SINGLE COMMAND)
########################################

ssm_exec() {
  local CMD="$1"

  aws ssm send-command \
    --region "$REGION" \
    --instance-ids "$INSTANCE_ID" \
    --document-name "AWS-RunShellScript" \
    --comment "platform exec" \
    --parameters "commands=[\"$CMD\"]" \
    --query "Command.CommandId" \
    --output text
}

########################################
# SSM EXEC (MULTI COMMAND)
########################################

ssm_exec_multi() {
  local SCRIPT="$1"

  aws ssm send-command \
    --region "$REGION" \
    --instance-ids "$INSTANCE_ID" \
    --document-name "AWS-RunShellScript" \
    --comment "platform multi exec" \
    --parameters "commands=$(printf '%s\n' "$SCRIPT" | jq -R . | jq -s .)" \
    --query "Command.CommandId" \
    --output text
}

########################################
# COMMANDS
########################################

case "$COMMAND" in

########################################
# UP
########################################

up)
  echo "Starting instance..."

  aws ec2 start-instances \
    --region "$REGION" \
    --instance-ids "$INSTANCE_ID" >/dev/null

  wait_for_running

  echo "Rehydrating..."
  ssm_exec "sudo /usr/local/bin/platform-rehydrate.sh"

  echo "✅ Platform UP"
;;

########################################
# DOWN
########################################

down)
  echo "Stopping platform..."

  ssm_exec "sudo systemctl stop ops.target || true"
  sleep 5

  aws ec2 stop-instances \
    --region "$REGION" \
    --instance-ids "$INSTANCE_ID" >/dev/null

  echo "✅ Platform DOWN"
;;

########################################
# REHYDRATE
########################################

rehydrate)
  echo "Running rehydrate..."
  CMD_ID=$(ssm_exec "sudo /usr/local/bin/platform-rehydrate.sh")
  echo "Command ID: $CMD_ID"
;;

########################################
# DEPLOY
########################################

deploy)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform deploy <service>"
    exit 1
  fi

  ROOT=$(git rev-parse --show-toplevel)
  SERVICE_DIR="$ROOT/apps/${SERVICE}/service"

  if [ ! -d "$SERVICE_DIR" ]; then
    echo "❌ Service not found"
    exit 1
  fi

  cd "$SERVICE_DIR"

  echo "Building image..."
  docker build -t ${SERVICE} .
  docker tag ${SERVICE}:latest $REGISTRY/${SERVICE}:latest

  aws ecr describe-repositories \
    --repository-names "$SERVICE" \
    --region "$REGION" >/dev/null 2>&1 || \
    aws ecr create-repository \
      --repository-name "$SERVICE" \
      --region "$REGION" >/dev/null

  aws ecr get-login-password --region "$REGION" | \
    docker login --username AWS --password-stdin $REGISTRY

  docker push $REGISTRY/${SERVICE}:latest

  CMD_ID=$(ssm_exec "sudo systemctl restart platform-${SERVICE} || true")

  echo "Command ID: $CMD_ID"
  echo "✅ Deployed"
;;

########################################
# REGISTER
########################################

register)
  SERVICE=$2
  PORT=$3
  DOMAIN=$4

  if [ -z "$SERVICE" ] || [ -z "$PORT" ] || [ -z "$DOMAIN" ]; then
    echo "❌ Usage: platform register <service> <port> <domain>"
    exit 1
  fi

  if [[ ! "$PORT" =~ ^[0-9]+$ ]]; then
    echo "❌ Invalid port"
    exit 1
  fi

  echo "Registering $SERVICE on port $PORT for $DOMAIN"

  SCRIPT=$(cat <<EOF
set -euo pipefail

mkdir -p /opt/platform/services

grep -qx "${SERVICE}" /opt/platform/services/services.list 2>/dev/null || \
  echo "${SERVICE}" >> /opt/platform/services/services.list

echo "${PORT}" > /opt/platform/services/${SERVICE}.port
echo "${DOMAIN}" > /opt/platform/services/${SERVICE}.domain

aws s3 sync /opt/platform/services s3://platform-api-services/platform/services

/usr/local/bin/platform-rehydrate.sh
EOF
)

  CMD_ID=$(ssm_exec_multi "$SCRIPT")

  echo "Command ID: $CMD_ID"
  echo "✅ Registered"
;;


########################################
# DEREGISTER
########################################

deregister)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform deregister <service>"
    exit 1
  fi

  echo "Deregistering $SERVICE..."

  SCRIPT=$(cat <<EOF
set -euo pipefail

SERVICES_DIR="/opt/platform/services"

if [ ! -f "\$SERVICES_DIR/services.list" ]; then
  echo "No services defined"
  exit 0
fi

sed -i "/^${SERVICE}\$/d" \$SERVICES_DIR/services.list || true
rm -f \$SERVICES_DIR/${SERVICE}.port
rm -f \$SERVICES_DIR/${SERVICE}.domain

aws s3 sync \$SERVICES_DIR s3://platform-api-services/platform/services --delete

/usr/local/bin/platform-rehydrate.sh
EOF
)

  CMD_ID=$(ssm_exec_multi "$SCRIPT")

  echo "Command ID: $CMD_ID"
  echo "🗑️ Removed"
;;

########################################
# RESTART
########################################

restart)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform restart <service>"
    exit 1
  fi

  CMD_ID=$(ssm_exec "sudo systemctl restart platform-${SERVICE} || true")

  echo "Command ID: $CMD_ID"
  echo "✅ Restarted"
;;

########################################
# LOGS
########################################

logs)
  CMD_ID=$(ssm_exec "sudo journalctl -u platform-${SERVICE} -n 100 --no-pager")
  echo "Command ID: $CMD_ID"
;;

########################################
# STATUS
########################################

status)
  CMD_ID=$(ssm_exec "systemctl status platform-${SERVICE} --no-pager")
  echo "Command ID: $CMD_ID"
;;

########################################
# SHELL
########################################

shell)
  aws ssm start-session \
    --region "$REGION" \
    --target "$INSTANCE_ID"
;;


list)
  aws s3 ls s3://platform-api-services/platform/services/
;;

describe)
  SERVICE=$2

  aws s3 cp s3://platform-api-services/platform/services/${SERVICE}.port -
  aws s3 cp s3://platform-api-services/platform/services/${SERVICE}.domain -
;;

state)
  aws s3 ls s3://platform-api-services/platform/services/
;;

state-pull)
  aws s3 sync s3://platform-api-services/platform/services ./services-state
;;

########################################
# DEFAULT
########################################

*)
  usage
;;

esac