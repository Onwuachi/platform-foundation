#!/usr/bin/env bash
set -euo pipefail

########################################
# CONFIG
########################################

TAG_KEY="Role"
TAG_VALUE="ops"
REGION="us-east-1"
REGISTRY="046685909731.dkr.ecr.us-east-1.amazonaws.com"

COMMAND="${1:-}"
SERVICE="${2:-}"

########################################
# HELP
########################################

usage() {
  cat <<EOF
Usage:
  platform up
  platform down
  platform rehydrate
  platform deploy <service>
  platform restart <service>
  platform logs <service>
  platform status <service>
  platform shell
EOF
  exit 1
}

########################################
# GET INSTANCE IDS BY TAG
########################################

get_instance_ids() {
  aws ec2 describe-instances \
    --region "$REGION" \
    --filters "Name=tag:${TAG_KEY},Values=${TAG_VALUE}" \
    --query "Reservations[].Instances[].InstanceId" \
    --output text
}

########################################
# WAIT FOR INSTANCE RUNNING
########################################

wait_for_running() {
  echo "Waiting for instance to be running..."

  for i in {1..30}; do
    STATE=$(aws ec2 describe-instances \
      --region "$REGION" \
      --filters "Name=tag:${TAG_KEY},Values=${TAG_VALUE}" \
      --query "Reservations[].Instances[].State.Name" \
      --output text)

    if [[ "$STATE" == "running" ]]; then
      echo "Instance is running"
      return
    fi

    sleep 5
  done

  echo "❌ Instance did not reach running state"
  exit 1
}

########################################
# SSM EXEC
########################################

ssm_exec() {
  local CMD="$1"

  aws ssm send-command \
    --region "$REGION" \
    --targets "Key=tag:${TAG_KEY},Values=${TAG_VALUE}" \
    --document-name "AWS-RunShellScript" \
    --parameters "commands=$CMD" \
    --query "Command.CommandId" \
    --output text
}

########################################
# COMMANDS
########################################

case "$COMMAND" in

########################################
# UP
########################################

up)
  IDS=$(get_instance_ids)

  if [ -z "$IDS" ]; then
    echo "❌ No instances found with tag ${TAG_KEY}=${TAG_VALUE}"
    exit 1
  fi

  echo "Starting instance(s): $IDS"

  aws ec2 start-instances \
    --region "$REGION" \
    --instance-ids $IDS >/dev/null

  wait_for_running

  echo "Rehydrating platform..."
  ssm_exec "sudo /usr/local/bin/platform-rehydrate.sh"

  echo "✅ Platform is UP"
;;

########################################
# DOWN
########################################

down)
  echo "Shutting down platform..."

  ssm_exec "sudo systemctl stop ops.target || true"

  sleep 5

  IDS=$(get_instance_ids)

  aws ec2 stop-instances \
    --region "$REGION" \
    --instance-ids $IDS >/dev/null

  echo "✅ Platform is DOWN"
;;

########################################
# REHYDRATE
########################################

rehydrate)
  echo "Running rehydrate..."

  ssm_exec "sudo /usr/local/bin/platform-rehydrate.sh"

  echo "✅ Rehydrate triggered"
;;

########################################
# DEPLOY
########################################

deploy)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform deploy <service>"
    exit 1
  fi

  ROOT=$(git rev-parse --show-toplevel)
  SERVICE_DIR="$ROOT/apps/${SERVICE}/service"

  if [ ! -d "$SERVICE_DIR" ]; then
    echo "❌ Service not found: $SERVICE"
    exit 1
  fi

  echo "Building Docker image..."
  cd "$SERVICE_DIR"

  docker build -t ${SERVICE} .
  docker tag ${SERVICE}:latest $REGISTRY/${SERVICE}:latest

  echo "Pushing to ECR..."

  aws ecr describe-repositories \
    --repository-names "$SERVICE" \
    --region "$REGION" >/dev/null 2>&1 || \
    aws ecr create-repository \
      --repository-name "$SERVICE" \
      --region "$REGION" >/dev/null

  aws ecr get-login-password --region "$REGION" | \
    docker login --username AWS --password-stdin $REGISTRY

  docker push $REGISTRY/${SERVICE}:latest

  echo "Deploying via SSM..."

  ssm_exec "sudo systemctl restart platform-${SERVICE} || true"

  echo "✅ Deployment triggered"
;;

########################################
# LOGS
########################################

logs)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform logs <service>"
    exit 1
  fi

  CMD_ID=$(ssm_exec "sudo journalctl -u platform-${SERVICE} -n 100 --no-pager")

  echo "Command ID: $CMD_ID"
  echo "👉 Check output in AWS SSM console"
;;

########################################
# STATUS
########################################

status)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform status <service>"
    exit 1
  fi

  CMD_ID=$(ssm_exec "systemctl status platform-${SERVICE} --no-pager")

  echo "Command ID: $CMD_ID"
  echo "👉 Check output in AWS SSM console"
;;


########################################
# DEFAULT
########################################

########################################
# RESTART
########################################

restart)
  if [ -z "$SERVICE" ]; then
    echo "❌ Usage: platform restart <service>"
    exit 1
  fi

  echo "Restarting $SERVICE via SSM..."

  CMD_ID=$(ssm_exec "sudo systemctl restart platform-${SERVICE} || true")

  echo "Command ID: $CMD_ID"
  echo "✅ Restart triggered"
;;

########################################
# SHELL (SSM SESSION)
########################################

shell)
  IDS=$(get_instance_ids)

  if [ -z "$IDS" ]; then
    echo "❌ No instances found"
    exit 1
  fi

  INSTANCE_ID=$(echo "$IDS" | awk '{print $1}')

  echo "Opening SSM shell to $INSTANCE_ID..."

  aws ssm start-session \
    --region "$REGION" \
    --target "$INSTANCE_ID"
;;


*)
  usage
;;

esac
