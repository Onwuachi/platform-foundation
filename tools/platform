#!/usr/bin/env bash
set -e

COMMAND=$1
SERVICE=$2
HOST="54.81.77.41"
BASE_PORT=3000
REGISTRY="046685909731.dkr.ecr.us-east-1.amazonaws.com"

########################################
# FUNCTIONS
########################################

get_port() {
  ssh -T -i ~/.ssh/onwua_key.pem \
    -o LogLevel=ERROR \
    -o StrictHostKeyChecking=no \
    ubuntu@$HOST <<EOF
PORT_FILE="/etc/platform/${SERVICE}.port"

if [ -f "\$PORT_FILE" ]; then
  cat "\$PORT_FILE"
else
  COUNT=\$(ls /etc/systemd/system/platform-*.service 2>/dev/null | wc -l)
  PORT=\$((3000 + COUNT * 10))
  echo \$PORT | sudo tee "\$PORT_FILE" > /dev/null
  echo \$PORT
fi
EOF
}

enable_service() {
  PORT=$1

  ssh -T -i ~/.ssh/onwua_key.pem -o LogLevel=ERROR -o StrictHostKeyChecking=no ubuntu@$HOST <<EOF

sudo mkdir -p /etc/platform
sudo touch /etc/platform/services.list

# Persist service (ONLY ONCE)
grep -qx "${SERVICE}" /etc/platform/services.list || \
  echo "${SERVICE}" | sudo tee -a /etc/platform/services.list > /dev/null

if [ ! -f /etc/systemd/system/platform-${SERVICE}.service ]; then

  echo "Creating service..."

  sudo tee /etc/haproxy/services/${SERVICE}.cfg > /dev/null <<ROUTE
backend ${SERVICE}_backend
  http-request replace-path ^/${SERVICE}/?(.*)$ /\1
  server ${SERVICE}1 127.0.0.1:${PORT} check
ROUTE

  sudo tee /etc/systemd/system/platform-${SERVICE}.service > /dev/null <<SERVICEFILE
[Unit]
Description=Platform ${SERVICE}
After=docker.service
Requires=docker.service

[Service]
Restart=always

ExecStartPre=-/usr/bin/docker rm -f platform-${SERVICE}
ExecStartPre=/bin/sh -c '/usr/local/bin/aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin ${REGISTRY}'

ExecStartPre=/usr/bin/docker pull ${REGISTRY}/${SERVICE}:latest

ExecStart=/usr/bin/docker run \\
  --name platform-${SERVICE} \\
  -p 127.0.0.1:${PORT}:3000 \\
  ${REGISTRY}/${SERVICE}:latest

ExecStop=/usr/bin/docker stop platform-${SERVICE}

[Install]
WantedBy=multi-user.target
SERVICEFILE

  sudo systemctl daemon-reload
  sudo systemctl enable platform-${SERVICE}

fi

sudo systemctl restart platform-${SERVICE}

# Validate HAProxy BEFORE reload
if sudo haproxy -c -f /etc/haproxy/haproxy.cfg -f /etc/haproxy/services/; then
  sudo systemctl reload haproxy
else
  echo "❌ HAProxy config invalid — not reloading"
  exit 1
fi

EOF
}

########################################
# COMMANDS
########################################

case "$COMMAND" in

deploy)
  echo "Deploying ${SERVICE}"

  ROOT=$(git rev-parse --show-toplevel)
  SERVICE_DIR="$ROOT/apps/${SERVICE}/service"

  if [ ! -d "$SERVICE_DIR" ]; then
    echo "Service directory not found"
    exit 1
  fi

  cd "$SERVICE_DIR"

  docker build -t ${SERVICE} .
  docker tag ${SERVICE}:latest $REGISTRY/${SERVICE}:latest

  aws ecr get-login-password --region us-east-1 | \
    docker login --username AWS --password-stdin $REGISTRY

  docker push $REGISTRY/${SERVICE}:latest

 PORT=$(get_port | tail -n1 | tr -dc '0-9')

  enable_service $PORT

  echo "Waiting for health..."

  for i in {1..20}; do
    STATUS=$(ssh -T -i ~/.ssh/onwua_key.pem -o LogLevel=ERROR -o StrictHostKeyChecking=no ubuntu@$HOST \
      "curl -s http://127.0.0.1:${PORT}/ready || true")

    if [[ $STATUS == *"ready"* ]]; then
      echo "✅ Deployment healthy"
      exit 0
    fi
    sleep 2
  done

  echo "❌ Deployment failed"
  exit 1
;;

logs)
  ssh -T -i ~/.ssh/onwua_key.pem -o LogLevel=ERROR -o StrictHostKeyChecking=no ubuntu@$HOST \
    "docker logs -f platform-${SERVICE}"
;;

status)
  ssh -T -i ~/.ssh/onwua_key.pem -o LogLevel=ERROR -o StrictHostKeyChecking=no ubuntu@$HOST \
    "systemctl status platform-${SERVICE}"
;;

restart)
  ssh -T -i ~/.ssh/onwua_key.pem -o LogLevel=ERROR -o StrictHostKeyChecking=no ubuntu@$HOST \
    "sudo systemctl restart platform-${SERVICE}"
;;

ssh)
  ssh -i ~/.ssh/onwua_key.pem ubuntu@$HOST
;;

*)
  echo "Usage:"
  echo "platform deploy <service>"
;;

esac

